@model IEnumerable<ClaimViewModel>
@{
    ViewData["Title"] = "My Loan Claims";
}

<div class="row animate-fade-in">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1 text-gradient-purple">My Claims</h2>
                <p class="text-secondary mb-0">Track status and review officer feedback for your submitted claims</p>
            </div>
            <a asp-action="Submit" class="btn btn-primary-custom">
                <i class="bi bi-file-earmark-plus-fill me-1"></i>New Claim
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="glass-panel p-5 text-center">
                <i class="bi bi-folder-x text-secondary" style="font-size: 4rem;"></i>
                <h4 class="mt-3 text-white">No Claims Found</h4>
                <p class="text-secondary">You haven't submitted any loan claims yet.</p>
                <a asp-action="Submit" class="btn btn-primary-custom mt-2">
                    Submit Your First Claim
                </a>
            </div>
        }
        else
        {
            <div class="glass-panel p-4">
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Claim ID</th>
                                <th>Loan Account</th>
                                <th>Claim Type</th>
                                <th>Date Submitted</th>
                                <th>Status</th>
                                <th class="text-end">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-white">#@claim.ClaimID</td>
                                    <td><code>@claim.LoanAccountNumber</code></td>
                                    <td>@claim.ClaimType</td>
                                    <td>@claim.DateSubmitted.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @if (claim.StatusID == 1)
                                        {
                                            <span class="badge-status badge-pending"><i class="bi bi-clock-history"></i>Pending</span>
                                        }
                                        else if (claim.StatusID == 2)
                                        {
                                            <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i>Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i>Rejected</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-secondary-custom btn-sm py-1 px-2" data-bs-toggle="collapse" data-bs-target="#desc-@claim.ClaimID">
                                            <i class="bi bi-eye"></i> View
                                        </button>
                                    </td>
                                </tr>
                                <!-- Accordion detail panel -->
                                <tr id="desc-@claim.ClaimID" class="collapse bg-dark-50">
                                    <td colspan="6" class="p-4" style="background-color: rgba(15, 23, 42, 0.25);">
                                        <div class="row">
                                            <div class="col-md-6 border-end border-secondary border-opacity-25">
                                                <h6 class="text-secondary font-weight-bold"><i class="bi bi-chat-left-text me-2 text-gradient-blue"></i>Description:</h6>
                                                <p class="text-white ps-3 mb-0" style="white-space: pre-wrap;">@claim.Description</p>
                                            </div>
                                            <div class="col-md-6">
                                                <h6 class="text-secondary font-weight-bold"><i class="bi bi-person-badge me-2 text-gradient-purple"></i>Review Status & Comments:</h6>
                                                <div class="ps-3">
                                                    @if (claim.StatusID == 1)
                                                    {
                                                        <span class="text-secondary italic">This claim is currently awaiting review by a Loan Officer.</span>
                                                    }
                                                    else
                                                    {
                                                        <div class="mb-2">
                                                            <strong class="text-secondary">Reviewed By:</strong> <span class="text-white">@claim.ReviewedByFullName</span>
                                                        </div>
                                                        <div class="mb-2">
                                                            <strong class="text-secondary">Review Date:</strong> <span class="text-white">@claim.ReviewDate?.ToString("yyyy-MM-dd HH:mm")</span>
                                                        </div>
                                                        <div>
                                                            <strong class="text-secondary">Officer Remarks:</strong> 
                                                            <p class="text-white mt-1 mb-0" style="white-space: pre-wrap;">@(string.IsNullOrEmpty(claim.OfficerComments) ? "No remarks provided." : claim.OfficerComments)</p>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
