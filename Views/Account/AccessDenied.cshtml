@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center mt-5 text-center animate-fade-in">
    <div class="col-md-6">
        <div class="glass-panel p-5">
            <i class="bi bi-shield-fill-x text-danger" style="font-size: 5rem;"></i>
            <h1 class="mt-4 text-gradient-purple">Access Denied</h1>
            <p class="text-secondary mt-3">You do not have permission to view this module. Please login with a different account that has appropriate credentials.</p>
            <div class="mt-4 d-flex justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Logout" class="btn btn-primary-custom">
                    <i class="bi bi-box-arrow-left me-1"></i>Login with Different Account
                </a>
            </div>
        </div>
    </div>
</div>
